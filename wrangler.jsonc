{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "psitsavibe",
  "compatibility_date": "2026-07-07",
  "workers_dev": true,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".deploy-assets"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "www.psitsavibe.com/*",
      "zone_name": "psitsavibe.com"
    }
  ]
}
